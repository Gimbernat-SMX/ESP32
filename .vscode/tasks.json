{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Compilar ejercicio ESP32",
            "type": "shell",
            "command": "bash",
            "args": [
                "${workspaceFolder}/compiler.sh",
                "${input:exercise}"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": []
        }
    ],
    "inputs": [
        {
            "id": "exercise",
            "type": "pickString",
            "description": "Selecciona el ejercicio a compilar",
            "options": [
                "ejercicio_1",
                "ejercicio_2"
            ],
            "default": "ejercicio_1"
        }
    ]
}
