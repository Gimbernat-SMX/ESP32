{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Compilar ejercicio ESP32",
            "type": "shell",
            "command": "bash",
            "args": [
                "${workspaceFolder}/.vscode/run_exercise.sh",
                "build"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": []
        }
    ]
}
